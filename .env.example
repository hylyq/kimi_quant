# Kimi Quant — Environment Variables
# Copy this file to .env and fill in your values

# === Kimi / Moonshot API (Required) ===
MOONSHOT_API_KEY=sk-your-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k3

# === DeepSeek API (Optional — Automatic Fallback) ===
# If configured, DeepSeek automatically takes over when Kimi API fails.
# Leave blank to use Kimi only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v3.1

# === LLM Parameters ===
# Which model to try first: "kimi" or "deepseek". The other becomes fallback.
PRIMARY_LLM=kimi
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# === Hyperliquid (Required for live trading) ===
# Private key of your Hyperliquid wallet (hex, without 0x prefix)
HYPERLIQUID_PRIVATE_KEY=
# Set to false for mainnet, true for testnet
HYPERLIQUID_TESTNET=true
# Mainnet API URL (unused if testnet is true)
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz

# === Trading Parameters ===
TRADING_PAIR=BTC
MAX_POSITION_SIZE=0.01
MIN_CONFIDENCE=0.7
MAX_LEVERAGE=3

# === Strategy ===
# Strategy mode: "single" (fast, one LLM call) or "debate" (multi-agent, 4 LLM calls)
STRATEGY_MODE=single
# Temperature for the Judge agent in debate mode (lower = more deterministic)
JUDGE_TEMPERATURE=0.05
# Seconds between trading cycles (600=10min, cost ~¥330/mo single or ~¥750/mo debate)
TRADING_INTERVAL=600
# Dry run mode: analyze but don't execute real orders
DRY_RUN=true

# === Logging ===
LOG_LEVEL=INFO
