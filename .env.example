# Kimi Quant — Environment Variables
# Copy this file to .env and fill in your values

# === Kimi / Moonshot API (Required) ===
MOONSHOT_API_KEY=sk-your-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k3

# === DeepSeek API (Optional — Automatic Fallback) ===
# If configured, DeepSeek automatically takes over when Kimi API fails.
# Leave blank to use Kimi only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# === LLM Parameters ===
# Which model to try first: "kimi" or "deepseek". The other becomes fallback.
PRIMARY_LLM=kimi
# Reasoning effort: "max" | "high" | "medium" | "low" | "minimal" | "off"
# Auto-translated to each model's native format (Kimi reasoning_effort, DeepSeek thinking)
REASONING_EFFORT=max
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# === Hyperliquid (Required for live trading) ===
# Private key of your Hyperliquid wallet (hex, without 0x prefix)
HYPERLIQUID_PRIVATE_KEY=
# Set to false for mainnet, true for testnet
HYPERLIQUID_TESTNET=true
# Mainnet API URL (unused if testnet is true)
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz

# === Trading Parameters ===
TRADING_PAIR=BTC
MAX_POSITION_SIZE=0.01
MIN_CONFIDENCE=0.7
MAX_LEVERAGE=3

# === Strategy ===
# Strategy mode: "single" (fast, one LLM call) or "debate" (multi-agent, 4-7 LLM calls)
STRATEGY_MODE=single
# Temperature for the Judge agent in debate mode (lower = more deterministic)
JUDGE_TEMPERATURE=0.05
# Judge's primary model (debate mode): "kimi" or "deepseek". Leave empty to use PRIMARY_LLM.
# Recommended: "kimi" for strong reasoning on final decisions, while debaters use cheaper DeepSeek.
JUDGE_PRIMARY_LLM=
# Enable rebuttal round in debate mode: debaters counter each other before Judge rules.
# Adds 3 extra LLM calls/cycle. Default: false. Only enable after validating basic debate works.
# DEBATE_REBUTTAL_ENABLED=false
# Seconds between trading cycles (600=10min, cost ~¥330/mo single or ~¥450/mo debate)
TRADING_INTERVAL=600
# Hard bounds for LLM-suggested wake intervals (seconds).
# MIN_INTERVAL=300   # default 5min — cost control floor
# MAX_INTERVAL=10800 # default 3h — prevent drifting too far in quiet markets
# Dry run mode: analyze but don't execute real orders
DRY_RUN=true

# === Notifications (optional — via larky Redis Pub/Sub) ===
# Redis connection for WeChat push. Defaults work if Redis is on localhost:6379.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# === Order Monitor (Real-time WebSocket + Flash LLM reporting) ===
# Enable real-time order status tracking via Hyperliquid WebSocket.
# When enabled, a background thread subscribes to orderUpdates and userFills,
# and a cheap Flash-level LLM generates push notifications for status changes.
MONITOR_ENABLED=true
# Flash model for generating report text (cheap, fast, no reasoning needed).
# Uses DeepSeek V4 Flash by default — ~$0.14/1M input tokens, <1s latency.
# Leave API key empty to reuse DEEPSEEK_API_KEY, or set your own.
MONITOR_FLASH_MODEL=deepseek-v4-flash
# MONITOR_FLASH_BASE_URL=https://api.deepseek.com/v1
# MONITOR_FLASH_API_KEY=

# === Logging ===
LOG_LEVEL=INFO
